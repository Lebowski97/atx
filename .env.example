# Convex deployment — created by `bunx convex dev`
CONVEX_DEPLOYMENT=

# Public Convex deployment URLs
CONVEX_URL=
CONVEX_SITE_URL=

# Client-side Convex URL used by both Next.js apps
NEXT_PUBLIC_CONVEX_URL=

# Store app secrets (required for passcode and session auth)
STOREFRONT_SERVER_SECRET=
STOREFRONT_SESSION_SECRET=

# HQ app auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Resend API key for transactional email (set via `bunx convex env set RESEND_API_KEY <key>`
# if you want it available to Convex functions)
RESEND_API_KEY=
